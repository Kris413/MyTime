{
  "manifest_version": 3,
  "name": "MyTime",
  "version": "1.0.0",
  "description": "记录和分析你的浏览器使用时间",
  "permissions": ["tabs", "storage", "alarms", "notifications", "idle"],
  "host_permissions": [
    "https://www.brainboom.top/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MyTime",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
